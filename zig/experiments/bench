#!/bin/sh
case "$1" in
	-n|--nofile|-nofile) ;;
	*)
		base=`hostname|sed 's/.*-/bench-/'`
		lastN=`ls $base*|sed 's/.*-\([0-9]*\).*/\1/'|sort -n|tail -1`
		n=`expr "$lastN" + 1`
		file="$HOME/$base-$n"
		exec >$file 2>&1
	;;
esac
OS_TYPE=$(uname -s)
ARCH=$(uname -m)

echo "--- Zag VM Benchmarking Environment ($ARCH-$OS_TYPE) ---"
case "$OS_TYPE" in
   Linux)
       # Linux Path: High Control
       echo "Isolation: ASLR Off, Core 4 Pinned"
       Prefix='setarch --addr-no-randomize taskset -c 4'
       ;;
    Darwin)
        # macOS Path: Best Effort
        echo "Isolation: DYLD Hint"
        echo "Note: macOS SIP may ignore ASLR disable hints. Ensure binary is linked with -no_pie."
        Prefix=''
        ;;
    *)
        echo "Unsupported OS."
        exit 1
        ;;
esac
tar zxf *.tgz 2>/dev/null
date
for i in */fib-*
do
    DYLD_NO_PIE=1 $Prefix $i --fib 40
done
date
